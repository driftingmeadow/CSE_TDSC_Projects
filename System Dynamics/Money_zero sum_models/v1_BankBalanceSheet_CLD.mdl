{UTF-8}
Deposit Inflow Rate  = A FUNCTION OF( Deposit Inflow Elasticity,Deposit Interest Rate\
		,Deposits) ~~|
Deposit Inflow Rate = Deposits * Deposit Inflow Elasticity * (Deposit Interest Rate -\
		 Alternative Return Rate)
	~	Lakh Crore/Year
	~	Rate of new deposits entering banking system
	|

BANK LOANS  = A FUNCTION OF( )
	~	
	~		|

Deposit Outflow Rate = Deposits * Deposit Outflow Elasticity * (Repo Rate - Borrowing Cost\
		)
	~	Lakh Crore/Year
	~	Rate of deposits being withdrawn
	|

Deposit Interest Rate = Repo Rate - 0.015
	~	Dmnl
	~	Interest paid on deposits
	|

Deposit Inflow Elasticity = 0.15
	~	Dmnl
	~	Sensitivity to interest rates
	|

Deposit Outflow Elasticity = 0.08
	~	Dmnl
	~	Withdrawal sensitivity
	|

Repo Rate = 0.065
	~	Dmnl
	~	RBI repo rate (POLICY LEVER)
	|

Borrowing Cost = Repo Rate - 0.01
	~	Dmnl
	~	Effective borrowing cost
	|

BANK BONDS = INTEG(Bond Inflow Rate - Bond Outflow Rate, 25.66)
	~	Lakh Crore
	~	Bank bonds (long-term debt liabilities)
	|

Bond Outflow Rate = BANK BONDS / 10
	~	Lakh Crore/Year
	~	Bonds mature and are repaid
	|

BANK EQUITY = INTEG(Equity Investment Rate - Equity Maturity Rate, 14.74)
	~	Lakh Crore
	~	Bank equity (accumulated net worth)
	|

Equity Investment Rate = Loan Interest Income + SLR Interest Income - Deposits * (Repo Rate\
		 - 0.015) - Deposits * 0.015 - BANK LOANS * NPA Ratio * 0.5 + External Capital Injection
	~	Lakh Crore/Year
	~	Equity grows from retained earnings and capital infusion
	|

Equity Maturity Rate = BANK EQUITY * 0.3
	~	Lakh Crore/Year
	~	Dividend payouts reduce equity
	|

External Capital Injection = 0
	~	Lakh Crore/Year
	~	Government recapitalization (exogenous)
	|

CRR Increase Rate = 0.04 * Deposit Inflow Rate
	~	Lakh Crore/Year
	~	When deposits flow in, 4% is reserved automatically
	|

CRR Decrease Rate = 0.04 * Deposit Outflow Rate
	~	Lakh Crore/Year
	~	When deposits withdrawn, CRR decreases
	|

SLR Maturity Rate = SLR INVESTMENTS / 3
	~	Lakh Crore/Year
	~	G-Secs mature and return cash
	|

SLR Interest Accrual Rate = SLR INVESTMENTS * (Repo Rate - 0.02)
	~	Lakh Crore/Year
	~	Interest on SLR (flows to CwB eventually)
	|

SLR Interest Income = SLR INVESTMENTS * (Repo Rate - 0.02)
	~	Lakh Crore/Year
	~	Interest income from securities
	|

Loan Origination Rate = MIN(Excess Reserves Available - 0.5, Deposits * 0.7) * (1 - NPA Ratio\
		)
	~	Lakh Crore/Year
	~	New loans originated from available excess reserves
	|

Loan Disbursement Rate = Loan Origination Rate
	~	Lakh Crore/Year
	~	Actual cash disbursement to borrowers
	|

Loan Repayment Rate = BANK LOANS * 0.015
	~	Lakh Crore/Year
	~	Monthly EMI collections from customers
	|

Loan WriteOff Rate = BANK LOANS * NPA Ratio * 0.5
	~	Lakh Crore/Year
	~	Non-performing loans written off
	|

Loan Interest Income = BANK LOANS * Loan Interest Rate
	~	Lakh Crore/Year
	~	Interest earned on loans (revenue)
	|

Loan Interest Rate = Repo Rate + 0.03 + 0.01
	~	Dmnl
	~	Loan rate = repo + credit spread + risk premium
	|

NPA Ratio = 0.025
	~	Dmnl
	~	Non-performing assets (2.5%)
	|

Capex Rate = BANK EQUITY * 0.02
	~	Lakh Crore/Year
	~	Capital expenditure (2% of equity per year)
	|

Depreciation Rate = OTHER BANK ASSETS / 10
	~	Lakh Crore/Year
	~	Straight-line depreciation (10-year average life)
	|

RBI reserve repo rate = Repo Rate
	~	Dmnl
	~	RBI's policy rate
	|

Deposit Interest Cost = Deposits * (Repo Rate - 0.015)
	~	Lakh Crore/Year
	~	Interest paid on deposits (flows out)
	|

Operating Costs = Deposits * 0.015
	~	Lakh Crore/Year
	~	Operating expenses (staff, rent, tech)
	|

Loan Provision Cost = BANK LOANS * NPA Ratio * 0.5
	~	Lakh Crore/Year
	~	Provisions against bad loans
	|

Net Interest Income = Loan Interest Income + SLR Interest Income - Deposit Interest Cost
	~	Lakh Crore/Year
	~	Net interest margin in flow form
	|

Profit Before Dividend = Net Interest Income - Operating Costs - Loan Provision Cost
	~	Lakh Crore/Year
	~	Operating profit (increases equity)
	|

TOTAL LIABILITIES = Deposits + BANK BONDS + BANK EQUITY
	~	Lakh Crore
	~	Total liabilities and equity
	|

BALANCE SHEET CHECK = TOTAL ASSETS - TOTAL LIABILITIES
	~	Lakh Crore
	~	Should equal zero (accounting identity)
	|

SLR to Deposit Ratio = SLR INVESTMENTS / Deposits
	~	Dmnl
	~	SLR as % of deposits (18% minimum, 28-35% actual)
	|

Capital Adequacy Ratio = BANK EQUITY / TOTAL ASSETS
	~	Dmnl
	~	Equity to assets (8-10% typical)
	|

Net Interest Margin = Net Interest Income / ((BANK LOANS + SLR INVESTMENTS) / 2)
	~	Dmnl
	~	Profitability ratio (2-3% typical)
	|

CRR Coverage = CRR REQUIREMENT / (0.04 * Deposits)
	~	Dmnl
	~	CRR compliance (should be 1.0)
	|

SLR Coverage = SLR INVESTMENTS / (0.18 * Deposits)
	~	Dmnl
	~	SLR compliance (should be >= 1.0)
	|

Reserve Buffer Ratio = Excess Reserves Available / 0.5
	~	Dmnl
	~	Excess reserves as multiple of minimum buffer
	|

INITIAL TIME = 0
	~	Year
	~	Initial simulation time
	|

TIME STEP = 0.03125
	~	Year
	~	Time step (monthly equivalent)
	|

SAVEPER = TIME STEP
	~	Year
	~	Save frequency
	|

